{
  "manifest_version": 3,
  "name": "Spoiler Shield",
  "version": "1.0",
  "description": "Blocks video thumbnails based on user-defined keywords.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["index.js"],
      "run_at": "document_idle"
    }
  ]
}
